@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2>Chi tiết sản phẩm</h2>

<div class="card p-3">
    <p><strong>Tên:</strong> @Model.Name</p>
    <p><strong>Giá:</strong> @Model.Price</p>
    <p><strong>Mô tả:</strong> @Model.Description</p>
    <p><strong>Danh mục:</strong> @Model.Category?.Name</p>

    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <img src="@Model.ImageUrl" width="200" />
    }
</div>

<p class="mt-3">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Quay lại</a>
</p>