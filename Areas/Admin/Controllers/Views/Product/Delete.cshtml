@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Xóa sản phẩm";
}

<h2>Xóa sản phẩm</h2>

<h4>Bạn có chắc muốn xóa sản phẩm này?</h4>

<div class="card p-3">
    <p><strong>Tên:</strong> @Model.Name</p>
    <p><strong>Giá:</strong> @Model.Price</p>
    <p><strong>Mô tả:</strong> @Model.Description</p>
</div>

<form asp-area="Admin" asp-controller="Product" asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Xóa</button>
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="btn btn-secondary">Hủy</a>
</form>