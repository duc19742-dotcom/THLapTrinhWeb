@using Microsoft.AspNetCore.Identity
@using WebsiteBanHang.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link text-light" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            Xin chào @UserManager.GetUserName(User)!
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="nav-link btn btn-link text-light border-0">Đăng xuất</button>
        </form>
    </li>
}
else
{
    <li class="nav-item d-flex align-items-center ms-lg-2">
        <a class="nav-link text-white-50 small me-2" asp-area="Identity" asp-page="/Account/Register">Đăng ký</a>
        <div class="vr bg-light opacity-25 my-2 me-2" style="height: 20px;"></div>
        <a class="btn btn-primary btn-sm px-4 fw-bold shadow-sm" asp-area="Identity" asp-page="/Account/Login">Đăng nhập</a>
    </li>
}