@model WebsiteBanHang.Models.ShoppingCart

@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="container mt-4">
    <h2>Giỏ hàng</h2>

    @if (!Model.Items.Any())
    {
        <p>Giỏ hàng của bạn đang trống.</p>
    }
    else
    {
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Ảnh</th>
                    <th>Giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" width="100" />
                            }
                        </td>
                        <td>@item.Price.ToString("N0") VNĐ</td>
                        <td>@item.Quantity</td>
                        <td>@((item.Price * item.Quantity).ToString("N0")) VNĐ</td>
                        <td>
                            <a asp-action="RemoveFromCart"
                               asp-route-productId="@item.ProductId"
                               class="btn btn-danger btn-sm">
                                Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <h4>Tổng tiền: @Model.GetTotal().ToString("N0") VNĐ</h4>

        <a asp-action="Checkout" class="btn btn-success">Thanh toán</a>
    }
</div>