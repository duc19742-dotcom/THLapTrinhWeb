@model WebsiteBanHang.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<h2>Chi Tiết Sản Phẩm</h2>

<div class="row">
    <div class="col-md-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid" style="max-width:250px;" />
        }
    </div>

    <div class="col-md-8">
        <h3>@Model.Name</h3>
        <p><strong>Giá:</strong> @Model.Price</p>
        <p><strong>Mô tả:</strong> @Model.Description</p>
        <p><strong>Loại:</strong> @Model.Category?.Name</p>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-primary">Chỉnh sửa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div>