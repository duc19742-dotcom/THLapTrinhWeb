@model WebsiteBanHang.Models.Product
@using WebsiteBanHang.Models

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Sản phẩm</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
      </ol>
    </nav>
    <div class="row bg-white p-4 rounded shadow-sm">
        <div class="col-md-5 text-center">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded border p-2" />
            }
        </div>
        <div class="col-md-7">
            <h2 class="fw-bold">@Model.Name</h2>
            <p class="badge bg-secondary">@Model.Category?.Name</p>
            <h3 class="text-danger fw-bold my-3">@Model.Price.ToString("C0", new System.Globalization.CultureInfo("vi-VN"))</h3>
            <p class="text-muted">@Model.Description</p>
            <hr />
            <div class="mt-4">
                <a asp-area="" asp-controller="ShoppingCart" asp-action="AddToCart" asp-route-id="@Model.Id" class="btn btn-lg btn-primary px-5"><i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng</a>
                @if (User.IsInRole(SD.Role_Admin))
                {
                    <a asp-action="Update" asp-route-id="@Model.Id" class="btn btn-lg btn-outline-info ms-2">Sửa</a>
                }
            </div>
        </div>
    </div>
</div>